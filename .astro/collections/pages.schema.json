{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "heroTitle": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "backgroundVideo": {
      "type": "string"
    },
    "buttons": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "link": {
            "type": "string"
          },
          "isExternal": {
            "type": "boolean"
          }
        },
        "required": [
          "text",
          "link"
        ]
      }
    },
    "contactLinks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "link": {
            "type": "string"
          },
          "isExternal": {
            "type": "boolean"
          }
        },
        "required": [
          "text",
          "link"
        ]
      }
    },
    "actionButton": {
      "type": "object",
      "properties": {
        "text": {
          "type": "string"
        },
        "link": {
          "type": "string"
        }
      },
      "required": [
        "text",
        "link"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title"
  ]
}