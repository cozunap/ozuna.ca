---
import { getEntry, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const aboutEntry = await getEntry('pages', 'about');
const { title, contactLinks } = aboutEntry.data;
const { Content } = await render(aboutEntry);
---

<Layout title={title} headerClass="solid-bg">
  <section class="page-section content-narrow">
    <h1 class="page-title text-center text-huge stroke-text">about</h1>
    
    <div class="text-center bounce-icon">
      <a href="#contact-carlos" style="color: inherit; text-decoration: none;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 612 792" width="75" height="75"><path fill="currentColor" d="M304.8,477.3c12.2-12.3,23.5-23.7,34.8-35c47.1-47.1,94.3-94.2,141.4-141.3c1.1-1.1,2.3-2.3,3.6-3.3 c3.3-2.4,7.5-2.1,10.2,0.8c2.7,2.8,3,7.1,0.6,10.3c-0.9,1.2-2,2.2-3.1,3.3c-58.9,58.8-117.8,117.7-176.7,176.5 c-1.4,1.4-2.8,2.9-4.2,4.3c-4,4-8.4,4-12.5-0.1c-13.7-13.7-27.3-27.5-41-41.2c-46.1-46.2-92.2-92.4-138.3-138.5 c-1.1-1.1-2.4-2.3-3.3-3.6c-2.2-3.2-1.7-7.3,1-9.9c2.6-2.6,7-3,10-0.8c1.2,0.9,2.2,2,3.3,3.1c57,57,113.9,114.1,170.9,171.2 C302.6,474.1,303.5,475.6,304.8,477.3z"></path></svg>
      </a>
    </div>

    <div class="page-content-text">
      <Content />
    </div>
  </section>

  <section id="contact-carlos" class="page-section bg-image-center text-center">
    <h2 class="section-title">Contact Carlos Ozuna</h2>
    
    {contactLinks && contactLinks.length > 0 && (
      <ul class="contact-links-list">
        {contactLinks.map((linkItem) => (
          <li>
            <a 
              href={linkItem.link} 
              target={linkItem.isExternal ? "_blank" : undefined} 
              class="contact-link"
            >
              {linkItem.text}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>


</Layout>
