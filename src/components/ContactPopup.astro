<style is:global>
  .contact-popup {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: #ffffff;
    z-index: 9999;
    transform: translateX(100vw);
    transition: transform 0.5s cubic-bezier(0.77, 0, 0.175, 1);
    display: flex;
    justify-content: center;
    align-items: center;
    color: #000;
  }
  .contact-popup.open {
    transform: translateX(0);
  }
  .contact-popup.closing-left {
    transform: translateX(-100vw);
  }
  .contact-popup-close {
    position: absolute;
    top: 30px;
    right: 40px;
    font-size: 50px;
    cursor: pointer;
    color: #000;
    font-family: var(--font-text);
    line-height: 1;
    transition: transform 0.3s ease;
  }
  .contact-popup-close:hover {
    transform: scale(1.1);
  }
  .contact-popup-content {
    width: 90%;
    max-width: 800px;
    text-align: center;
  }
  .contact-popup-title {
    font-family: var(--font-heading);
    font-size: clamp(30px, 5vw, 55px);
    margin-bottom: 50px;
    letter-spacing: 2px;
  }
  .contact-popup .stroke-text {
    color: transparent;
    -webkit-text-stroke: 1px #000;
  }
  .contact-popup-form {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .contact-popup-form .form-row {
    display: flex;
    gap: 30px;
  }
  .contact-popup-form .form-row input,
  .contact-popup-form .form-row textarea {
    flex: 1;
    border: none;
    border-bottom: 1px solid #777;
    padding: 10px 5px;
    font-family: var(--font-text);
    font-size: 16px;
    background: transparent;
    outline: none;
    color: #000;
    transition: border-color 0.3s ease;
  }
  .contact-popup-form .form-row input:focus,
  .contact-popup-form .form-row textarea:focus {
    border-bottom-color: #f3202e;
  }
  .contact-popup-form .form-row input::placeholder,
  .contact-popup-form .form-row textarea::placeholder {
    color: #999;
  }
  .contact-popup-form .form-row textarea {
    resize: vertical;
  }
  @media (max-width: 768px) {
    .contact-popup-form .form-row {
      flex-direction: column;
      gap: 30px;
    }
  }
  .btn-submit-popup {
    background-color: #051024;
    color: white;
    border: none;
    font-family: var(--font-text);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 2px;
    padding: 20px;
    margin-top: 10px;
    cursor: pointer;
    text-transform: uppercase;
    transition: background-color 0.3s ease;
  }
  .btn-submit-popup:hover {
    background-color: #f3202e;
  }
  
  /* WhatsApp Floating Button */
  .whatsapp-float {
    position: fixed;
    bottom: 30px;
    right: 30px;
    display: flex;
    align-items: center;
    gap: 15px;
    z-index: 10000;
    text-decoration: none;
  }
  .whatsapp-text {
    background: white;
    padding: 10px 15px;
    border-radius: 20px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    font-size: 12px;
    color: #333;
    font-family: var(--font-text);
    opacity: 0;
    transform: translateX(10px);
    transition: all 0.3s ease;
  }
  .whatsapp-float:hover .whatsapp-text {
    opacity: 1;
    transform: translateX(0);
  }
  .whatsapp-icon {
    background: #f3202e;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    box-shadow: 0 4px 15px rgba(243, 32, 46, 0.4);
    transition: transform 0.3s ease;
  }
  .whatsapp-icon svg {
    width: 35px;
    height: 35px;
    fill: white;
  }
  .whatsapp-float:hover .whatsapp-icon {
    transform: scale(1.1);
  }
  
  /* Lock body scroll when popup is open */
  body.popup-open {
    overflow: hidden;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const popup = document.getElementById('contact-popup');
    const closeBtn = document.getElementById('contact-popup-close');
    const openBtns = document.querySelectorAll('.btn-open-popup');
    
    if (popup && closeBtn) {
      openBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          popup.classList.add('open');
          document.body.classList.add('popup-open');
        });
      });
      
      closeBtn.addEventListener('click', () => {
        popup.classList.remove('open');
        popup.classList.add('closing-left');
        
        setTimeout(() => {
          popup.style.transition = 'none';
          popup.classList.remove('closing-left');
          // Force reflow
          void popup.offsetWidth;
          popup.style.transition = '';
          document.body.classList.remove('popup-open');
        }, 500);
      });
    }
  });
</script>
