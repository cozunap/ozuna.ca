---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Carlos Ozuna | Senior Graphic Designer & Web Developer">
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-video-bg">
      <video autoplay loop muted playsinline class="hero-video-element">
        <source src="/assets/videos/designer-working.mp4" type="video/mp4">
      </video>
    </div>
    <div class="hero-overlay"></div>
    
    <div class="hero-content">
      <h2 class="hero-title">Welcome to<br><span>Carlos Ozuna's</span> portfolio</h2>
      
      <div class="hero-buttons">
        <a href="/assets/docs/CV.pdf" target="_blank" class="btn btn-primary btn-animated">Download CV</a>
        <a href="/work" class="btn btn-primary btn-animated">go to portfolio</a>
      </div>
    </div>
  </section>
</Layout>
